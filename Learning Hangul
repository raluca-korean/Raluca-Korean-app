<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Learning Hangul</title>

<style>
body {
  font-family: sans-serif;
  background: #f5f6fa;
  margin: 0;
  text-align: center;
}

.header {
  background: #58cc02;
  color: white;
  padding: 16px;
  font-size: 20px;
}

/* BOARD */
.board {
  margin: 20px auto;
  width: 280px;
  height: 280px;
  background: white;
  border-radius: 20px;
  position: relative;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

/* LETTER */
.letter {
  position: absolute;
  top: 40px;
  width: 100%;
  font-size: 120px;
  color: #ddd;
}

/* STROKE GUIDE */
.guide {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

/* CANVAS */
canvas {
  position: absolute;
  top: 0;
  left: 0;
}

/* BUTTONS */
.controls {
  margin-top: 20px;
}

button {
  padding: 12px 20px;
  border-radius: 12px;
  border: none;
  margin: 5px;
  font-size: 16px;
}

.repeat {
  background: #ffcc00;
}

.next {
  background: #58cc02;
  color: white;
}

/* LEVEL */
.level {
  margin-top: 10px;
  color: gray;
}

</style>
</head>

<body>

<div class="header">Learning Hangul</div>

<div class="level" id="level">Level: Letters</div>

<div class="board">
  <div id="letter" class="letter">ㄱ</div>
  <canvas id="canvas" width="280" height="280"></canvas>
</div>

<div class="controls">
  <button onclick="playSound()">🔊 Sound</button>
  <button class="repeat" onclick="clearCanvas()">Repeat</button>
  <button class="next" onclick="next()">Next</button>
</div>

<script>

/* DATA STRUCTURE */
const levels = [
  {
    name: "Letters",
    data: ["ㄱ","ㄴ","ㄷ","ㅁ","ㅂ"]
  },
  {
    name: "Syllables",
    data: ["가","나","다","마","바"]
  },
  {
    name: "Words",
    data: ["사람","학교","바다"]
  },
  {
    name: "Sentences",
    data: ["나는 간다","학교에 간다"]
  }
];

let levelIndex = 0;
let itemIndex = 0;

/* CANVAS */
const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");

let drawing = false;

canvas.addEventListener("mousedown", () => drawing = true);
canvas.addEventListener("mouseup", () => drawing = false);
canvas.addEventListener("mousemove", draw);

canvas.addEventListener("touchstart", () => drawing = true);
canvas.addEventListener("touchend", () => drawing = false);
canvas.addEventListener("touchmove", drawTouch);

function draw(e){
  if(!drawing) return;
  ctx.lineWidth = 5;
  ctx.lineCap = "round";
  ctx.strokeStyle = "#4a6cff";

  ctx.lineTo(e.offsetX, e.offsetY);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(e.offsetX, e.offsetY);
}

function drawTouch(e){
  e.preventDefault();
  if(!drawing) return;

  const rect = canvas.getBoundingClientRect();
  const x = e.touches[0].clientX - rect.left;
  const y = e.touches[0].clientY - rect.top;

  ctx.lineWidth = 5;
  ctx.lineCap = "round";
  ctx.strokeStyle = "#4a6cff";

  ctx.lineTo(x, y);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(x, y);
}

/* CLEAR */
function clearCanvas(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
}

/* NEXT */
function next(){
  clearCanvas();

  itemIndex++;

  if(itemIndex >= levels[levelIndex].data.length){
    levelIndex++;
    itemIndex = 0;

    if(levelIndex >= levels.length){
      alert("Completed!");
      return;
    }
  }

  update();
}

/* UPDATE */
function update(){
  document.getElementById("letter").innerText =
    levels[levelIndex].data[itemIndex];

  document.getElementById("level").innerText =
    "Level: " + levels[levelIndex].name;
}

/* AUDIO */
function playSound(){
  const text = levels[levelIndex].data[itemIndex];
  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = "ko-KR";
  speechSynthesis.speak(utter);
}

/* INIT */
update();

</script>

</body>
</html>
