<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<title>vocab-korean.json/title>

<style>

body{
font-family:system-ui;
background:#f5f6fb;
padding:20px;
}

table{
border-collapse:collapse;
width:100%;
background:white;
}

th,td{
border:1px solid #ddd;
padding:6px;
}

select,input{
width:100%;
border:none;
outline:none;
}

button{
margin-top:10px;
padding:6px 10px;
}

#output{
margin-top:20px;
width:100%;
height:120px;
}

</style>

</head>

<body>

<h1>Sentence Builder</h1>

<table id="builder">

<thead>

<tr>
<th>Clause</th>
<th>Subject</th>
<th>Object</th>
<th>Modifier</th>
<th>Verb</th>
<th>Connector</th>
</tr>

</thead>

<tbody>

</tbody>

</table>

<button onclick="addClause()">Add Clause</button>
<button onclick="buildSentence()">Build Sentence</button>

<textarea id="output"></textarea>


<script>

/* -------------------
VOCABULARY
------------------- */

let vocab={}

async function loadVocab(){

const res = await fetch("vocab-korean.json")

vocab = await res.json()

addClause()

}

window.onload=loadVocab


/* -------------------
CREATE SELECT
------------------- */

function createSelect(list){

const select=document.createElement("select")

list.forEach(word=>{

const option=document.createElement("option")

option.value=word
option.textContent=word

select.appendChild(option)

})

return select

}


/* -------------------
ADD CLAUSE
------------------- */

function addClause(){

const tbody=document.querySelector("#builder tbody")

const row=document.createElement("tr")

row.innerHTML="<td>Clause</td>"

const subject=createSelect(vocab.subjects)
const object=createSelect(vocab.objects)
const modifier=createSelect(vocab.modifiers)
const verb=createSelect(vocab.verbs)
const connector=createSelect(vocab.connectors)

row.appendChild(cell(subject))
row.appendChild(cell(object))
row.appendChild(cell(modifier))
row.appendChild(cell(verb))
row.appendChild(cell(connector))

tbody.appendChild(row)

}

function cell(el){

const td=document.createElement("td")

td.appendChild(el)

return td

}


/* -------------------
BUILD SENTENCE
------------------- */

function buildSentence(){

const rows=document.querySelectorAll("#builder tbody tr")

let sentence=""

rows.forEach(row=>{

const selects=row.querySelectorAll("select")

const subject=selects[0].value
const object=selects[1].value
const modifier=selects[2].value
const verb=selects[3].value
const connector=selects[4].value

sentence += `${modifier} ${subject} ${object} ${verb} ${connector} `

})

document.getElementById("output").value=sentence

}

</script>

</body>

</html>
